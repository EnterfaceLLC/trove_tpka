{
  "expo": {
    "name": "Trove TPKA",
    "slug": "trove_tpka",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icons/icon.png",
    "scheme": "trovetpka",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1B26",
        "foregroundImage": "./src/assets/images/icons/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.dotenterface.trove_tpka"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./src/assets/images/icons/favicon.ico"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/icons/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#1A1B26"
        }
      ],
      "@maplibre/maplibre-react-native/app.plugin.js",
      "expo-health-connect",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "01b6f74f-747f-43fe-80fa-be9a42381ce1"
      }
    }
  }
}
